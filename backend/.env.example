APP_NAME=StockPilot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Tunis

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=oracle
DB_HOST=oracle
DB_PORT=1521
DB_DATABASE=XEPDB1
DB_USERNAME=stockpilot
DB_PASSWORD=secret
DB_PREFIX=

CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache TTLs (seconds)
CACHE_TTL_SUGGESTIONS=21600
CACHE_TTL_FORECASTS=86400
CACHE_TTL_ANOMALIES=3600

JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

OPENAI_API_KEY=sk-...
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@stockpilot.tn
MAIL_FROM_NAME="${APP_NAME}"

SUPER_ADMIN_EMAIL=admin@stockpilot.tn
SUPER_ADMIN_PASSWORD=SuperAdmin@2025
