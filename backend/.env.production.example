# ─────────────────────────────────────────────────────────────────────────────
# StockPilot — Production environment (alwaysdata)
# Copy this file to backend/.env on the server and fill in the real values.
# Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=StockPilot
APP_ENV=production
# Generate once locally with: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
# Public URL of your alwaysdata site (e.g. https://stockpilot.alwaysdata.net
# or your custom domain)
APP_URL=https://your-account.alwaysdata.net
APP_TIMEZONE=Africa/Tunis

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database — MySQL (alwaysdata) ────────────────────────────────────────────
# Create the database in the alwaysdata admin panel (Databases → MySQL), then
# copy the connection details here. On alwaysdata the values look like:
#   DB_HOST=mysql-<account>.alwaysdata.net
#   DB_DATABASE=<account>_stockpilot
#   DB_USERNAME=<account>  (or a dedicated user <account>_app)
DB_CONNECTION=mysql
DB_HOST=mysql-your-account.alwaysdata.net
DB_PORT=3306
DB_DATABASE=your-account_stockpilot
DB_USERNAME=your-account
DB_PASSWORD=

# ── Cache / Queue / Session (no Redis needed for a single instance) ──────────
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
FILESYSTEM_DISK=local

# Cache TTLs (seconds)
CACHE_TTL_SUGGESTIONS=21600
CACHE_TTL_FORECASTS=86400
CACHE_TTL_ANOMALIES=3600

# ── JWT (tymon/jwt-auth) ─────────────────────────────────────────────────────
# Generate once locally with: php artisan jwt:secret --show
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

# ── OpenAI (AI catalog, forecasts, anomalies) ────────────────────────────────
# Without a valid key the app gracefully falls back to offline sector catalogs.
OPENAI_API_KEY=sk-your-real-key
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_MAX_TOKENS_PRODUCTS=2500
OPENAI_MAX_TOKENS_CATALOG=3800

# ── Mail (optional) ──────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@stockpilot.tn
MAIL_FROM_NAME="${APP_NAME}"

# ── Initial super-admin (consumed by the seeder) ─────────────────────────────
SUPER_ADMIN_EMAIL=admin@stockpilot.tn
SUPER_ADMIN_PASSWORD=ChangeMe@2026
